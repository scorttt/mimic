                        // release //

rule: "[IE] :: Released Primary"
Event.OngoingPlayer
if (!IsDummyBot())
if (!IsButtonHeld(player, Button.PrimaryFire) || IsDead())
{
    Player[] bots = owner_bots;
    StopHoldingButton(bots, Button.PrimaryFire);
}

