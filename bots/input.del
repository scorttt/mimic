rule: "[IE] :: Pressed Primary"
Event.OngoingPlayer
if (!IsDummyBot())
if (IsButtonHeld(player, Button.PrimaryFire))
if (IsAlive())
{
    Player[] bots = owner_bots;
    StartHoldingButton(bots, Button.PrimaryFire);
}

rule: "[IE] :: Pressed Secondary"
